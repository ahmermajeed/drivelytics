# ──────────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────────
# Local Postgres (matches docker-compose.yml). We use port 5433 (not 5432) to
# avoid colliding with other Postgres containers commonly running on 5432.
DATABASE_URL="postgresql://drivelytics:drivelytics@localhost:5433/drivelytics?schema=public"

# ──────────────────────────────────────────────────────────────────────────
# AI provider — pick ONE of the blocks below
# ──────────────────────────────────────────────────────────────────────────

# ─── Option A — Groq (FREE, recommended for testing) ──────────────────────
# Sign up at https://console.groq.com/keys, create a key, paste below.
# Generous free tier, sub-second latency.
#
# Use `openai/gpt-oss-20b` — it was trained on the OpenAI tool-calling
# format and handles it reliably. Llama-3.3 on Groq sometimes emits
# malformed tool calls (see "tool_use_failed" errors).
#
# AI_PROVIDER="openai"
# OPENAI_API_KEY="gsk_..."
# OPENAI_BASE_URL="https://api.groq.com/openai/v1"
# OPENAI_MODEL="openai/gpt-oss-20b"

# ─── Option B — Google Gemini (FREE) ──────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
#
# AI_PROVIDER="openai"
# OPENAI_API_KEY="AIza..."
# OPENAI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
# OPENAI_MODEL="gemini-2.0-flash"

# ─── Option C — Ollama (FREE, fully local; needs decent CPU/GPU) ──────────
# Install Ollama, then `ollama pull qwen2.5:7b`, then `ollama serve`.
#
# AI_PROVIDER="openai"
# OPENAI_API_KEY="ollama"             # any non-empty string works
# OPENAI_BASE_URL="http://localhost:11434/v1"
# OPENAI_MODEL="qwen2.5:7b"

# ─── Option D — OpenAI (paid) ─────────────────────────────────────────────
# AI_PROVIDER="openai"
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"

# ─── Option E — Anthropic Claude (paid) ───────────────────────────────────
# AI_PROVIDER="anthropic"
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-3-5-haiku-latest"

# ──────────────────────────────────────────────────────────────────────────
# Active AI config (uncomment / fill in from one of the blocks above)
# ──────────────────────────────────────────────────────────────────────────
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL=""
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=""

# ──────────────────────────────────────────────────────────────────────────
# WhatsApp worker (Phase 3) — only needed when running `npm run whatsapp`
# ──────────────────────────────────────────────────────────────────────────

# Comma-separated list of WhatsApp numbers allowed to talk to the bot.
# Use international format, digits only (e.g. Pakistan +92 → "923001234567").
# Anyone NOT on this list is silently ignored.
AI_ALLOWED_PHONES=""

# Optional: send a daily briefing to this number when there are
# expiring/overdue rentals. Same format as above.
AI_BRIEFING_PHONE=""

# Optional: cron schedule and timezone for the briefing.
# Default: every day at 9:00 AM Asia/Karachi.
AI_BRIEFING_CRON="0 9 * * *"
AI_BRIEFING_TIMEZONE="Asia/Karachi"

# Worker control plane (used by the dashboard WhatsApp button).
# Locally: bound to 127.0.0.1 (default), no token needed.
# In cloud: set HOST="0.0.0.0" and a long random TOKEN; set WA_CONTROL_BASE_URL
#          on the dashboard side to the worker's public URL.
WA_CONTROL_PORT="3001"
WA_CONTROL_HOST="127.0.0.1"
WA_CONTROL_TOKEN=""

# Where the dashboard's /api/whatsapp/* proxies forward to. Leave empty
# locally (defaults to http://127.0.0.1:${WA_CONTROL_PORT}). In production
# set this to the worker's public URL e.g. https://drivelytics-worker.koyeb.app
WA_CONTROL_BASE_URL=""

# ──────────────────────────────────────────────────────────────────────────
# Gmail — incoming email summarization
# ──────────────────────────────────────────────────────────────────────────

# OAuth client credentials from Google Cloud Console:
#   1. https://console.cloud.google.com → create project
#   2. Enable Gmail API
#   3. APIs & Services → Credentials → + Create OAuth client ID
#      Type: "Desktop app". No redirect URIs to register.
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""

# How often to poll the inbox for unread emails (ms). Floor 15s.
GMAIL_POLL_INTERVAL_MS="60000"

# Phone (digits only, country code first) that receives email-derived
# WhatsApp alerts. Falls back to AI_BRIEFING_PHONE if blank.
GMAIL_NOTIFY_PHONE=""
