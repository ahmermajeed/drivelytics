// Drivelytics — Postgres schema.
// Phase 1: only Car. Phase 5+ adds Customer, Payment, MaintenanceReminder, etc.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Car {
  /// Stable, human-friendly id. Kept as String to preserve compatibility with
  /// the legacy xlsx-era ids (e.g. "c_lx9k2abcd"). New rows generated by
  /// `genId()` follow the same scheme.
  id          String    @id

  carName     String
  model       String

  /// Person/company the car is rented to. Optional — kept nullable so
  /// pre-existing rows that never captured this don't need backfilling.
  rentedTo    String?

  /// Nullable because the spreadsheet workflow allowed missing dates.
  dateRented  DateTime? @db.Date
  rentedTill  DateTime? @db.Date

  /// Float (double precision) matches the existing JS `number` math used
  /// throughout the dashboard. Switch to Decimal if you ever need exact
  /// currency arithmetic — but that's a downstream-touching change.
  rentedPrice Float     @default(0)
  advancePaid Float     @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([rentedTill])
  @@index([carName])
}

/// Persistent Baileys auth state for the WhatsApp worker.
///
/// `key` mirrors the filename Baileys' `useMultiFileAuthState` would have
/// used (e.g. "creds", "pre-key-12345", "session-abc@1.42") prefixed with a
/// namespace for future multi-account support.
///
/// `value` is JSON-stringified using Baileys' BufferJSON replacer so Buffers
/// round-trip cleanly. `@db.Text` ensures we don't hit the default VARCHAR
/// length limit for large key blobs.
model WhatsAppAuth {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/// OAuth tokens for the email integration.
///
/// `provider` lets us support multiple email backends down the road without
/// another schema change ("gmail", "outlook", ...). For now we always
/// store one row per logical account; the worker reads `provider="gmail"`
/// by default (configurable).
///
/// The access token is short-lived (~1h) — we refresh it transparently
/// using the long-lived refresh token. Some providers rotate refresh
/// tokens on every refresh, so we always persist whatever the latest
/// response gave us back.
model EmailAuth {
  id                   String   @id
  provider             String   @default("gmail")
  refreshToken         String   @db.Text
  accessToken          String   @db.Text
  accessTokenExpiresAt DateTime
  /// Email address of the linked account, captured from id_token for
  /// display / debugging. Optional.
  email                String?
  updatedAt            DateTime @updatedAt
}

